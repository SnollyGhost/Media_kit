rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // Inquiry Validation
    function isValidInquiry(data) {
      let requiredFields = ['name', 'email', 'phone', 'package', 'createdAt', 'status', 'preferredMethod'];
      
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.phone is string && data.phone.size() > 0 &&
             data.status == 'pending' &&
             data.createdAt is timestamp;
    }

    match /inquiries/{inquiryId} {
      // Allow any user to submit an inquiry if it passes validation
      allow create: if isValidInquiry(incoming());
      
      // Only admins can read or manage inquiries
      allow read, update, delete: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
