rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // Inquiry Validation
    function isValidInquiry(data) {
      let requiredFields = ['name', 'email', 'phone', 'package', 'createdAt', 'status', 'preferredMethod'];
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.email is string && data.email.size() >= 5 && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() >= 5 && data.phone.size() <= 20 &&
             data.package is string && data.package.size() >= 1 && data.package.size() <= 100 &&
             data.status == 'pending' &&
             data.preferredMethod in ['telegram', 'whatsapp', 'email'] &&
             data.createdAt == request.time &&
             (!('company' in data) || (data.company is string && data.company.size() <= 100)) &&
             (!('message' in data) || (data.message is string && data.message.size() <= 2000));
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(incoming());
      allow read, update, delete: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
